# Copy this file to .env and fill in your real values for LOCAL testing.
# NEVER commit the real .env file to version control.
#
# ON RENDER: you do not upload this file. Instead, type each of these
# same KEY=value pairs into the Render dashboard under your web
# service's "Environment" tab.
#
# Exceptions that should NOT be set manually on Render:
#   - DATABASE_URL: copy the Internal Database URL from your assistant-db
#     Postgres instance's info page and paste it in manually (we are not
#     using render.yaml's fromDatabase auto-injection for this project,
#     consistent with how the social agent project was set up).
#   - PORT: Render sets this itself. The start command uses --port $PORT.

# --- WhatsApp Cloud API (Meta) ---
# These come from a NEW Meta App + NEW test number, separate from the
# ai-social-agent project's app/number.
WHATSAPP_PHONE_NUMBER_ID=your_new_test_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=choose_any_random_string_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# Your real personal WhatsApp number, E.164 without the +, e.g. 254712345678
# This is the number you'll message FROM and that the assistant replies TO.
# Must be added as a verified recipient on Meta's test number while in dev mode.
USER_PHONE_NUMBER=254700000000

# --- AI services ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Used for: intent classification, drafting messages/emails

OPENAI_API_KEY=your_openai_api_key_here
# Used for: voice note transcription only (Whisper endpoint of the same API).
# No separate signup needed - same key you already have.

# --- Database ---
# Local: postgresql://localhost:5432/assistant_dev (or sqlite for quick local testing)
# Render: paste the Internal Database URL from the assistant-db instance
DATABASE_URL=postgresql://user:password@localhost:5432/assistant_dev

# --- App config ---
DEFAULT_TIMEZONE=Africa/Nairobi
# Used as the fallback timezone for new users (briefing time, reminder firing, etc.)

PUBLIC_BASE_URL=https://your-render-service-url.onrender.com
# Set this AFTER your first deploy, once you know the real URL. Needed for
# building any links sent back in WhatsApp messages.

WEBHOOK_PORT=8000
# Used only for local uvicorn runs. Unused on Render (it uses $PORT instead).
